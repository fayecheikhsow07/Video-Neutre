# Environment Configuration

# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/video_neutre
DATABASE_POOL_SIZE=5

# Redis
REDIS_URL=redis://redis:6379

# MinIO Storage
MINIO_URL=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=video-neutre

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=False

# File Upload
MAX_FILE_SIZE=512000000  # 500MB in bytes
ALLOWED_VIDEO_FORMATS=mp4,webm,mkv,avi,mov
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,gif,webp

# Processing
MAX_VIDEO_DURATION=3600  # 1 hour in seconds
PROCESSING_TIMEOUT=1800  # 30 minutes
WORKER_COUNT=4

# JWT
JWT_SECRET=your-secret-key-change-this
JWT_EXPIRATION=86400

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
